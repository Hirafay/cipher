{
  "name": "cipher",
  "version": "1.1.0",
  "description": "Cipher - A customizable terminal UI for system monitoring, network analysis, and penetration testing",
  "author": "Hirafay <hirafay07@gmail.com> (https://github.com/Hirafay)",
  "license": "GPL-3.0",
  "main": "src/_boot.js",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hirafay/cipher.git"
  },
  "bugs": {
    "url": "https://github.com/Hirafay/cipher/issues"
  },
  "homepage": "https://github.com/Hirafay/cipher#readme",
  "scripts": {
    "start": "electron src --nointro",
    "dev": "electron src",
    "prebuild-linux": "rsync -a --info=progress2 src/ prebuild-src --exclude node_modules && node prebuild-minify.js && cd prebuild-src && npm install",
    "prebuild-darwin": "rsync -a src/ prebuild-src --exclude node_modules && node prebuild-minify.js && cd prebuild-src && npm install",
    "prebuild-windows": "mkdir prebuild-src && xcopy src\\* prebuild-src\\ /E /C /Q /Y && node prebuild-minify.js && cd prebuild-src && npm install",
    "build-linux": "./node_modules/.bin/electron-builder build -l --x64 --ia32 --arm64 --armv7l --publish never",
    "build-darwin": "./node_modules/.bin/electron-builder build -m --publish never",
    "build-windows": "node_modules\\.bin\\electron-builder build -w --publish never",
    "build": "npm run prebuild-windows && npm run build-windows && npm run postbuild-windows",
    "postbuild-linux": "rm -R prebuild-src",
    "postbuild-darwin": "rm -R prebuild-src",
    "postbuild-windows": "rmdir /S /Q prebuild-src",
    "init-file-icons": "git submodule update --init",
    "update-file-icons": "git submodule foreach git pull origin master && node file-icons-generator.js"
  },
  "build": {
    "appId": "com.hirafay.cipher",
    "productName": "Cipher",
    "asar": true,
    "compression": "normal",
    "copyright": "Copyright © 2024 Hirafay (https://github.com/Hirafay). Based on edex-ui by GitSquared.",
    "directories": {
      "output": "dist",
      "app": "prebuild-src"
    },
    "forceCodeSigning": false,
    "npmRebuild": true,
    "artifactName": "cipher-${version}-${os}-${arch}.${ext}",
    "linux": {
      "target": [
        "AppImage"
      ],
      "category": "System",
      "icon": "media/linuxIcons"
    },
    "appImage": {
      "artifactName": "cipher-${version}-linux-${arch}.AppImage"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "category": "public.app-category.utilities",
      "icon": "media/icon.icns"
    },
    "dmg": {
      "artifactName": "cipher-${version}-macos-${arch}.dmg"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64",
            "ia32"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "media/icon.ico"
    },
    "nsis": {
      "artifactName": "cipher-${version}-windows-${arch}.exe",
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "deleteAppDataOnUninstall": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Cipher"
    }
  },
  "dependencies": {
    "clean-css": "^5.3.3",
    "electron": "^31.7.7",
    "electron-builder": "^24.13.3",
    "mime-types": "^2.1.35",
    "node-json-minify": "1.0.0",
    "terser": "^5.31.6"
  },
  "optionalDependencies": {
    "cson-parser": "4.0.9"
  }
}